{
  "info": {
    "_postman_id": "clb-api-collection",
    "name": "CLB API — École La Bonté",
    "description": "API de consultation CLB API.\n\nAuthentification :\n1. Exécuter **Auth > Login** (téléphone + PIN) — le token de session est enregistré automatiquement.\n2. Ou définir `apiToken` dans les variables pour le token technique (API_TOKEN).\n\nLes requêtes protégées utilisent `Authorization: Bearer {{authToken}}` (sessionToken si défini, sinon apiToken).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "apiToken", "value": "votre-api-token" },
    { "key": "sessionToken", "value": "" },
    { "key": "authToken", "value": "" },
    { "key": "parentId", "value": "1007" },
    { "key": "eleveId", "value": "1868" },
    { "key": "anneescolaireId", "value": "4" },
    { "key": "telephone", "value": "+243997031460" },
    { "key": "pin", "value": "1234" },
    { "key": "mois", "value": "July" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{authToken}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const session = pm.collectionVariables.get('sessionToken');",
          "const api = pm.collectionVariables.get('apiToken');",
          "pm.collectionVariables.set('authToken', session || api || '');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Endpoints publics (pas d'authentification requise).",
      "item": [
        {
          "name": "Login (téléphone + PIN)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telephone\": \"{{telephone}}\",\n  \"pin\": \"{{pin}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Connexion parent. Enregistre automatiquement `sessionToken` et `parentId`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('sessionToken', json.token);",
                  "    if (json.parent && json.parent.id) {",
                  "        pm.collectionVariables.set('parentId', json.parent.id);",
                  "    }",
                  "    pm.test('Token de session enregistré', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Changer PIN",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telephone\": \"{{telephone}}\",\n  \"current_pin\": \"{{pin}}\",\n  \"new_pin\": \"5678\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/change-pin",
            "description": "Modifier le PIN (4 à 6 chiffres). `current_pin` = PIN actuel ou DEFAULT_PIN."
          }
        }
      ]
    },
    {
      "name": "Abonnements",
      "item": [
        {
          "name": "Liste des abonnements",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/abonnements?actif=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "abonnements"],
              "query": [
                { "key": "actif", "value": "", "description": "1 ou true = abonnements actifs" }
              ]
            },
            "description": "Liste tous les abonnements. Paramètre optionnel `actif`."
          }
        },
        {
          "name": "Détail abonnement",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/abonnements/1",
            "description": "Remplacer l'ID dans l'URL."
          }
        }
      ]
    },
    {
      "name": "Absences agents",
      "item": [
        {
          "name": "Liste des absences agents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/absences?agentaffectation_id=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "absences"],
              "query": [
                { "key": "agentaffectation_id", "value": "", "description": "Filtre par affectation agent" }
              ]
            }
          }
        },
        {
          "name": "Détail absence agent",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/absences/1"
          }
        }
      ]
    },
    {
      "name": "Absences élèves",
      "item": [
        {
          "name": "Liste des absences élèves",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/absences-eleves?eleve=&classe=&section=&anneescolaire=2025/2026&statut=&date_debut=&date_fin=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "absences-eleves"],
              "query": [
                { "key": "eleve", "value": "", "description": "Recherche partielle nom élève" },
                { "key": "classe", "value": "", "description": "Recherche partielle classe" },
                { "key": "section", "value": "", "description": "Recherche partielle section" },
                { "key": "anneescolaire", "value": "2025/2026" },
                { "key": "statut", "value": "" },
                { "key": "date_debut", "value": "", "description": "ex. 2025-09-01" },
                { "key": "date_fin", "value": "" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Élèves",
      "item": [
        {
          "name": "Recherche par téléphone tuteur",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/eleves?numero_telephone_tuteur={{telephone}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "eleves"],
              "query": [
                { "key": "numero_telephone_tuteur", "value": "{{telephone}}", "description": "Requis" }
              ]
            }
          }
        },
        {
          "name": "Élèves par parent",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/eleves/by-parent/{{parentId}}"
          }
        },
        {
          "name": "Absences d'un élève",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/eleves/{{eleveId}}/absences"
          }
        },
        {
          "name": "Détail élève",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/eleves/{{eleveId}}"
          }
        }
      ]
    },
    {
      "name": "Paiements",
      "item": [
        {
          "name": "Liste des paiements",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/paiements?eleve_id={{eleveId}}&tarification_id=&mois={{mois}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "paiements"],
              "query": [
                { "key": "eleve_id", "value": "{{eleveId}}" },
                { "key": "tarification_id", "value": "" },
                { "key": "mois", "value": "{{mois}}" }
              ]
            }
          }
        },
        {
          "name": "Paiements élève — année scolaire",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/paiements/eleve/{{eleveId}}/annee-scolaire/{{anneescolaireId}}"
          }
        },
        {
          "name": "Paiements élève — année scolaire courante",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/paiements/eleve/{{eleveId}}/annee-scolaire-courante"
          }
        },
        {
          "name": "Paiements élève — par mois",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/paiements/eleve/{{eleveId}}/mois/{{mois}}",
            "description": "Valeur exacte du champ paiement.mois (ex. July, pas de mois)."
          }
        },
        {
          "name": "Détail paiement",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/paiements/16570"
          }
        }
      ]
    },
    {
      "name": "Tarifications",
      "item": [
        {
          "name": "Liste des tarifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tarifications?nom=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tarifications"],
              "query": [
                { "key": "nom", "value": "", "description": "Recherche partielle (ex. Inscription)" }
              ]
            }
          }
        },
        {
          "name": "Détail tarification",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tarifications/5"
          }
        }
      ]
    }
  ]
}
